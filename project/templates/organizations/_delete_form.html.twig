{{ include('partials/_delete_confirmation_modal.html.twig') }}

<form method="post" action="{{ path('app_organization_delete', {'id': organization.id}) }}" onsubmit="return confirm('¿Estás seguro que deseas eliminar esta organización?');" class="inline-block">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ organization.id) }}">
    <button class="inline-flex items-center px-2 py-1 text-xs font-medium rounded text-white bg-red-600 hover:bg-red-700 transition-colors duration-200">
        <i class="bi bi-trash me-1"></i><span class="hidden sm:inline">Eliminar</span>
    </button>
</form>
