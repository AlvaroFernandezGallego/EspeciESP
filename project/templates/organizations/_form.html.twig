{{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {% for field in form %}
            {% if field.vars.name != '_token' %}
                <div class="{% if field.vars.name in ['description', 'address'] %}col-span-1 md:col-span-2{% endif %}">
                    {{ form_label(field, null, {'label_attr': {'class': 'block text-sm font-medium text-[#213448] mb-1'}}) }}
                    {{ form_widget(field, {
                        'attr': {
                            'class': 'w-full px-3 py-2 border border-[#ECEFCA] rounded-md shadow-sm text-sm focus:ring-[#547792] focus:border-[#547792] ' ~
                                    (field.vars.name in ['description', 'address'] ? 'h-32' : '')
                        }
                    }) }}
                    {{ form_errors(field, {'attr': {'class': 'mt-1 text-sm text-red-600'}}) }}
                </div>
            {% endif %}
        {% endfor %}
    </div>
    <div class="flex justify-end space-x-2 pt-4">
        <a href="{{ path('app_organizations_index') }}" class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-[#213448] bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#547792] transition-colors duration-200">
            <i class="bi bi-x-lg me-2"></i>Cancelar
        </a>
        <button type="submit" class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-[#ECEFCA] bg-[#213448] hover:bg-[#547792] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#547792] transition-colors duration-200">
            <i class="bi bi-check-lg me-2"></i>{{ button_label|default('Guardar') }}
        </button>
    </div>
{{ form_end(form) }}
