{% extends 'base.html.twig' %}

{% block title %}Especies | EspeciESP{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
            <div>
                <h1 class="text-2xl font-semibold text-[#213448]">Especies</h1>
                <p class="mt-1 text-sm text-[#547792]">Gestión de especies en peligro de extinción</p>
            </div>
            <div class="mt-4 md:mt-0">
                <a href="{{ path('app_species_new') }}" class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-[#ECEFCA] bg-[#213448] hover:bg-[#547792] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#547792] transition-colors duration-200">
                    <i class="bi bi-plus-lg me-2"></i>Nueva Especie
                </a>
            </div>
        </div>

        <div class="bg-white shadow-sm rounded-lg overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-[#213448]">
                        <tr>
                            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-[#ECEFCA] uppercase tracking-wider">Nombre Científico</th>
                            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-[#ECEFCA] uppercase tracking-wider">Nombre Común</th>
                            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-[#ECEFCA] uppercase tracking-wider hidden md:table-cell">Categoría</th>
                            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-[#ECEFCA] uppercase tracking-wider hidden md:table-cell">Estado</th>
                            <th scope="col" class="relative px-4 py-3 w-20">
                                <span class="sr-only">Acciones</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                    {% for species in species %}
                        <tr class="hover:bg-gray-50">
                            <td class="px-4 py-2 text-sm font-medium text-[#213448] max-w-[200px] truncate">{{ species.scientificName }}</td>
                            <td class="px-4 py-2 text-sm text-[#547792] max-w-[200px] truncate">{{ species.commonName }}</td>
                            <td class="px-4 py-2 text-sm text-[#547792] hidden md:table-cell">{{ species.category ? species.category.name : '' }}</td>
                            <td class="px-4 py-2 text-sm text-[#547792] hidden md:table-cell">{{ species.status ? species.status.name : '' }}</td>
                            <td class="px-4 py-2 text-sm text-right">
                                <div class="flex flex-col sm:flex-row justify-end gap-1">
                                    <a href="{{ path('app_species_show', {'id': species.id}) }}" 
                                       class="inline-flex items-center px-2 py-1 text-xs font-medium rounded text-[#ECEFCA] bg-[#547792] hover:bg-[#94B4C1] transition-colors duration-200">
                                        <i class="bi bi-eye me-1"></i><span class="hidden sm:inline">Ver</span>
                                    </a>
                                    <a href="{{ path('app_species_edit', {'id': species.id}) }}" 
                                       class="inline-flex items-center px-2 py-1 text-xs font-medium rounded text-[#ECEFCA] bg-[#547792] hover:bg-[#94B4C1] transition-colors duration-200">
                                        <i class="bi bi-pencil me-1"></i><span class="hidden sm:inline">Editar</span>
                                    </a>
                                    {{ include('species/_delete_form.html.twig') }}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-4 py-2 text-sm text-center text-[#547792]">No se encontraron especies registradas.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
