{% extends 'base.html.twig' %}

{% block title %}Nueva Especie | EspeciESP{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
            <div>
                <h1 class="text-2xl font-semibold text-[#213448]">Nueva Especie</h1>
                <p class="mt-1 text-sm text-[#547792]">Añade una nueva especie al sistema</p>
            </div>
            <div class="mt-4 md:mt-0">
                <a href="{{ path('app_species_index') }}" class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-[#ECEFCA] bg-[#213448] hover:bg-[#547792] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#547792] transition-colors duration-200">
                    <i class="bi bi-arrow-left me-2"></i>Volver al listado
                </a>
            </div>
        </div>

        <div class="bg-white shadow-sm rounded-lg p-6">
            {{ include('species/_form.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
