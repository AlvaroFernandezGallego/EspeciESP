{% extends 'base.html.twig' %}

{% block head %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block title %}Error {{ status_code }} | EspeciESP{% endblock %}

{% block body %}
    <div class="min-h-screen bg-gray-50 flex flex-col justify-center items-center px-4">
        <div class="max-w-md w-full text-center">
            <div class="mb-8">
                <h1 class="text-6xl font-bold text-[#213448] mb-4">{{ status_code }}</h1>
                <p class="text-xl text-[#547792] mb-2">
                    {% if status_code == 400 %}
                        Solicitud incorrecta
                    {% elseif status_code == 401 %}
                        No autorizado
                    {% elseif status_code == 403 %}
                        Acceso denegado
                    {% elseif status_code == 404 %}
                        Página no encontrada
                    {% elseif status_code == 405 %}
                        Método no permitido
                    {% elseif status_code == 408 %}
                        Tiempo de espera agotado
                    {% elseif status_code == 429 %}
                        Demasiadas solicitudes
                    {% elseif status_code == 500 %}
                        Error del servidor
                    {% elseif status_code == 502 %}
                        Puerta de enlace incorrecta
                    {% elseif status_code == 503 %}
                        Servicio no disponible
                    {% elseif status_code == 504 %}
                        Tiempo de espera de la puerta de enlace
                    {% else %}
                        Ha ocurrido un error
                    {% endif %}
                </p>
                <p class="text-[#213448]/80 mb-8">
                    {% if status_code == 400 %}
                        La solicitud enviada no pudo ser procesada. Por favor, verifica los datos e inténtalo de nuevo.
                    {% elseif status_code == 401 %}
                        Necesitas iniciar sesión para acceder a esta página.
                    {% elseif status_code == 403 %}
                        No tienes permisos para acceder a esta página.
                    {% elseif status_code == 404 %}
                        Lo sentimos, la página que buscas no existe.
                    {% elseif status_code == 405 %}
                        El método de solicitud utilizado no está permitido para esta página.
                    {% elseif status_code == 408 %}
                        La solicitud ha tardado demasiado tiempo. Por favor, verifica tu conexión e inténtalo de nuevo.
                    {% elseif status_code == 429 %}
                        Has realizado demasiadas solicitudes. Por favor, espera un momento antes de intentarlo de nuevo.
                    {% elseif status_code == 500 %}
                        Ha ocurrido un error en el servidor. Por favor, inténtalo más tarde.
                    {% elseif status_code == 502 %}
                        El servidor está temporalmente fuera de servicio. Por favor, inténtalo más tarde.
                    {% elseif status_code == 503 %}
                        El servicio no está disponible en este momento. Por favor, inténtalo más tarde.
                    {% elseif status_code == 504 %}
                        El servidor tardó demasiado tiempo en responder. Por favor, inténtalo más tarde.
                    {% else %}
                        Ha ocurrido un error inesperado. Por favor, inténtalo de nuevo o contacta con el soporte técnico.
                    {% endif %}
                </p>
                <div class="flex flex-col sm:flex-row justify-center items-center space-y-4 sm:space-y-0 sm:space-x-4">
                    <a href="{{ path('app_home') }}" class="inline-flex items-center px-6 py-3 bg-[#547792] text-[#ECEFCA] rounded-md hover:bg-[#547792]/90 transition-colors">
                        <svg class="h-5 w-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                        Volver a inicio
                    </a>
                    {% if status_code == 401 %}
                        <a href="{{ path('app_login') }}" class="inline-flex items-center px-6 py-3 border border-[#547792] text-[#547792] rounded-md hover:bg-[#547792]/10 transition-colors">
                            <svg class="h-5 w-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                            </svg>
                            Iniciar sesión
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %} 